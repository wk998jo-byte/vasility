run = "npm run build:web && PORT=8080 npm start"
modules = ["nodejs-20", "postgresql-16", "python-3.11"]

[packager]
ignoredPackages = ["firebase"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
ADMIN_USER = "admin"
FACILITY_USER = "facility_user"
TWILIO_WHATSAPP_NUMBER = "whatsapp:+15739201367"
TWILIO_WHATSAPP_FROM = "whatsapp:+15739201367"
TWILIO_MESSAGING_SERVICE_SID = "MG4081b893c03fa182181fcaad117b3a59"
TWILIO_TEMPLATE_WELCOME = "HX6e9593b826b3e3a2ab3d3b2e64589c18"
TWILIO_TEMPLATE_ADMIN = "HX5ac827c6ea10ff3114d5602d575f7d67"
TWILIO_TEMPLATE_DONE = "HXbd1985f4517e39cd2993d3f250fea082"
TWILIO_TEMPLATE_SID = "HXbd1985f4517e39cd2993d3f250fea082"
TWILIO_SMS_NUMBER = "+15739201367"
ADMIN_WHATSAPP = "+966530089716"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && PORT=8080 npm start"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"

# App listens on 8080 (default in server/index.js). Map it to external :80
# so Preview / Publish work. Mismatch (e.g. localPort 5000 while app opens
# 8080) shows: "Port :8080 opened, but has missing configuration."
[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
# Must match [[ports]].localPort — Replit health checks that port only.
run = ["sh", "-c", "PORT=8080 npm start"]
build = ["npm", "run", "build"]

[nix]
channel = "stable-25_05"
