run = "npm run build:web && npm start"
modules = ["nodejs-20", "postgresql-16", "python-3.11"]

[packager]
ignoredPackages = ["firebase"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
ADMIN_USER = "admin"
FACILITY_USER = "facility_user"
WHATSAPP_API_URL = "https://api.ultramsg.com/instance184225/messages/chat"
TWILIO_WHATSAPP_FROM = "whatsapp:+15739201367"
TWILIO_TEMPLATE_WELCOME = "HX8aaa173e0ba33a1e1c70a86d30145760"
TWILIO_TEMPLATE_DONE = "HX9987669bbd573aef9e2b262e0885ee65"
ADMIN_WHATSAPP = "+966530089716"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && PORT=5000 npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]

[nix]
channel = "stable-25_05"
