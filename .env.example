# Copy to .env and fill in your values for local dev or Replit Secrets.
# NEVER commit .env with real credentials.

PORT=8080

# ─── Required for MVP ─────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/qr

# Admin authentication (seeded on first run if users table is empty)
ADMIN_USER=admin
ADMIN_PASS=replace-with-strong-password-min-12-chars

# Facility staff user (seeded if missing)
FACILITY_USER=facility_user
FACILITY_PASS=replace-with-strong-password-min-12-chars

# JWT signing secret — use a long random string (32+ characters)
JWT_SECRET=replace-with-long-random-secret-min-32-characters

# Public URL for QR codes (set to your Replit app URL in production)
VITE_PUBLIC_BASE_URL=https://your-repl-name.replit.app

# ─── Optional (not required for MVP) ────────────────────────────────────────

# SMTP notifications — optional; falls back to console.log if unset
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_FROM=noreply@example.com
# NOTIFY_EMAIL=admin@example.com
# SMTP_SECURE=false

# Issue photo uploads — optional future feature; NOT required for MVP.
# QR codes are generated client-side from room tokens (not uploaded anywhere).
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# WhatsApp resolved-ticket notifications — optional; falls back to console stub if unset.
#
# Option A: CallMeBot (free; each recipient registers once at callmebot.com
# and gets a personal apikey). Map phones to apikeys, comma-separated:
# CALLMEBOT_KEYS=+966501234567:123456,+966559876543:654321
#
# Option B: Any gateway that accepts a JSON POST { to, message, ticketNumber, status }
# (e.g. Twilio, UltraMsg, Meta Graph API via a gateway).
# WHATSAPP_API_URL=https://api.your-provider.com/send
# WHATSAPP_API_TOKEN=optional-bearer-token
